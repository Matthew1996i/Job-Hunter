# Job Hunter - Configurações de Ambiente
# Copie este arquivo para .env e preencha com seus dados

# API do Groq (obrigatório)
# Obtenha em: https://console.groq.com
GROQ_API_KEY=sk_live_

# MongoDB (opcional - usa padrões se não definido)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=job_hunter

# LinkedIn (opcional - para scraping do feed)
LINKEDIN_LI_AT=

# Outras configurações (opcional)
HEADLESS=false
LOG_LEVEL=INFO
